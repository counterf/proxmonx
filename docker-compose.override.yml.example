# Development overrides
# Copy to docker-compose.override.yml to use
#
# Mounts backend source for hot-reload during development.
# Frontend dev: run `npm run dev` in frontend/ separately (Vite on port 5173).

services:
  proxmon:
    build:
      context: .
      dockerfile: Dockerfile
    volumes:
      - ./backend/app:/app/app
    environment:
      - LOG_LEVEL=debug
    command: sh -c "exec uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-3000} --reload"
