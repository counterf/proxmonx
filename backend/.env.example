# Proxmox connection (required)
PROXMOX_HOST=https://192.168.1.10:8006
PROXMOX_TOKEN_ID=proxmon@pve!monitor
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_NODE=pve

# Discovery settings
POLL_INTERVAL_SECONDS=300
DISCOVER_VMS=false
VERIFY_SSL=false

# SSH settings for Docker inspection
SSH_USERNAME=root
SSH_KEY_PATH=/app/ssh/id_rsa
# SSH_PASSWORD=  # Alternative to key-based auth
# Path to known_hosts file for strict SSH host key verification.
# If unset, unknown host keys are accepted with a warning (WarningPolicy).
# SSH_KNOWN_HOSTS_PATH=/app/ssh/known_hosts

# GitHub token (optional, raises rate limit from 60/h to 5000/h)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS origins (comma-separated or JSON list)
# CORS_ORIGINS=http://localhost:3000,http://frontend

# Application
LOG_LEVEL=info
PROXMON_ENABLED=true
SSH_ENABLED=true
